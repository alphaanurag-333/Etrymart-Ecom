# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Local example:
MONGODB_URI=mongodb://127.0.0.1:27017/Etrymart_Ecommerce

# --- JWT: access tokens (login / register — used now) ---
JWT_SECRET=Etrymart_secret
JWT_EXPIRES_IN=7d

# --- JWT: optional separate keys (defaults to JWT_SECRET if unset) ---
# Used when you add refresh tokens, signed reset links, or email verification.
JWT_REFRESH_SECRET=Etrymart_secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_PASSWORD_SECRET=Etrymart_secret
JWT_RESET_PASSWORD_EXPIRES_IN=1h
JWT_VERIFY_EMAIL_SECRET=Etrymart_secret
JWT_VERIFY_EMAIL_EXPIRES_IN=24h

# --- Firebase Admin (optional) ---
# Download the service account JSON from Firebase Console; keep the file outside the repo
# or in a path listed here — do not commit the JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=D:/path/to/your-service-account.json
